<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ title ?? "{{app_name}}" }</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="stylesheet" href="/css/app.css">
    <link rel="stylesheet" href="/css/tabler-icons.min.css">
    <script defer src="/js/alpine.min.js"></script>
    <script src="/js/htmx.min.js"></script>
    <style>
        @font-face {
            font-family: 'tabler-icons';
            src: url('/fonts/tabler-icons.woff2') format('woff2');
            font-weight: normal;
            font-style: normal;
        }
    </style>
</head>
<body x-data="{{dark: true, sidebarOpen: false, drawerOpen: false, moreOpen: false}}"
      :data-theme="dark ? 'dark' : 'light'"
      class="bg-base-100 text-base-content min-h-screen">

    <!-- Toast -->
    <div
        x-data="{{show: false, message: '', type: 'success'}}"
        @item-saved.window="message = 'Saved!'; type = 'success'; show = true; setTimeout(() => show = false, 3000)"
        @item-deleted.window="message = 'Deleted!'; type = 'error'; show = true; setTimeout(() => show = false, 3000)"
        x-show="show"
        x-transition
        class="toast toast-top toast-end z-50">
        <div :class="type === 'success' ? 'alert alert-success' : 'alert alert-error'">
            <span x-text="message"></span>
        </div>
    </div>

    <main class="min-h-screen">
        { slot }
    </main>

</body>
</html>
