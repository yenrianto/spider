<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ title ?? "{{app_name}}" }</title>
    <link rel="stylesheet" href="/css/app.css">
    <link rel="stylesheet" href="/css/tabler-icons.min.css">
    <script defer src="/js/alpine.min.js"></script>
    <script src="/js/htmx.min.js"></script>
    <style>
        @font-face {
            font-family: 'tabler-icons';
            src: url('/fonts/tabler-icons.woff2') format('woff2');
            font-weight: normal;
            font-style: normal;
        }
    </style>
</head>
<body x-data="appShell()"
      class="min-h-screen"
      style="background:#0f0f0f;">

    <!-- NAVBAR -->
    <nav style="height:52px; background:#141414; border-bottom:0.5px solid #2a2a2a; display:flex; align-items:center; padding:0 16px; gap:10px; position:fixed; top:0; left:0; right:0; z-index:30;">
        <button class="lg:hidden" @click="drawerOpen = !drawerOpen" aria-label="menu">
            <i class="ti ti-menu-2" style="font-size:20px; color:#888;"></i>
        </button>
        <div style="display:flex; align-items:center; gap:8px;">
            <div style="width:26px; height:26px; background:#a3e635; border-radius:5px; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; color:#0f0f0f;">S</div>
            <span style="font-size:14px; font-weight:500; color:#fff;">{{app_name}}</span>
        </div>
        <div style="margin-left:auto; display:flex; align-items:center; gap:8px;">
            <button style="width:30px; height:30px; border-radius:6px; border:0.5px solid #2a2a2a; background:transparent; display:flex; align-items:center; justify-content:center; color:#666; cursor:pointer;" aria-label="notifications">
                <i class="ti ti-bell" style="font-size:15px;"></i>
            </button>
            <div style="width:30px; height:30px; border-radius:50%; background:#a3e635; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; color:#0f0f0f; cursor:pointer;">JD</div>
        </div>
    </nav>

    <!-- DESKTOP ASIDE -->
    <aside class="hidden lg:flex"
           :style="sidebarOpen ? 'width:200px' : 'width:52px'"
           style="position:fixed; top:52px; left:0; bottom:0; background:#141414; border-right:0.5px solid #2a2a2a; flex-direction:column; align-items:center; padding:8px 0; transition:width 0.25s cubic-bezier(.4,0,.2,1); overflow:hidden; z-index:20;">

        <button @click="sidebarOpen = !sidebarOpen"
                style="width:32px; height:32px; border-radius:6px; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#555; background:transparent; border:none; margin-bottom:6px; flex-shrink:0;">
            <i class="ti ti-menu-2" style="font-size:15px;"></i>
        </button>

        <div style="display:flex; flex-direction:column; gap:2px; width:100%; padding:0 6px;">
            <a href="/" style="height:34px; border-radius:6px; display:flex; align-items:center; gap:10px; padding:0 8px; color:#a3e635; position:relative; text-decoration:none; white-space:nowrap;">
                <span style="position:absolute; left:0; top:50%; transform:translateY(-50%); width:2px; height:16px; background:#a3e635; border-radius:0 2px 2px 0;"></span>
                <i class="ti ti-home" style="font-size:16px; flex-shrink:0;"></i>
                <span x-show="sidebarOpen" style="font-size:13px; color:#a3e635;">Home</span>
            </a>
            <!-- SPIDER:NAV_ITEMS -->
        </div>

        <div style="margin-top:auto; width:100%; padding:0 6px;">
            <div style="height:0.5px; background:#2a2a2a; margin:6px 8px;"></div>
            <a href="/settings" style="height:34px; border-radius:6px; display:flex; align-items:center; gap:10px; padding:0 8px; color:#555; text-decoration:none; white-space:nowrap;">
                <i class="ti ti-settings" style="font-size:16px; flex-shrink:0;"></i>
                <span x-show="sidebarOpen" style="font-size:13px; color:#888;">Settings</span>
            </a>
            <a href="/logout" style="height:34px; border-radius:6px; display:flex; align-items:center; gap:10px; padding:0 8px; color:#555; text-decoration:none; white-space:nowrap;">
                <i class="ti ti-logout" style="font-size:16px; flex-shrink:0;"></i>
                <span x-show="sidebarOpen" style="font-size:13px; color:#888;">Logout</span>
            </a>
        </div>
    </aside>

    <!-- MOBILE DRAWER OVERLAY -->
    <div x-show="drawerOpen"
         @click="drawerOpen = false"
         style="position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:40; display:none;"
         class="lg:hidden">
    </div>

    <!-- MOBILE SIDE DRAWER -->
    <div :class="drawerOpen ? 'translate-x-0' : '-translate-x-full'"
         style="position:fixed; top:52px; left:0; bottom:56px; width:200px; background:#141414; border-right:0.5px solid #2a2a2a; z-index:50; transition:transform 0.25s cubic-bezier(.4,0,.2,1); padding:8px 6px;"
         class="lg:hidden">
        <a href="/" style="height:36px; border-radius:6px; display:flex; align-items:center; gap:10px; padding:0 10px; color:#a3e635; text-decoration:none;">
            <i class="ti ti-home" style="font-size:16px;"></i>
            <span style="font-size:13px;">Home</span>
        </a>
        <!-- SPIDER:DRAWER_ITEMS -->
    </div>

    <!-- MAIN CONTENT -->
    <main :style="'padding-top:52px;' + (sidebarOpen ? 'padding-left:200px' : 'padding-left:52px')"
          style="transition:padding-left 0.25s cubic-bezier(.4,0,.2,1); min-height:100vh;"
          class="lg:block pb-16 lg:pb-0">
        { slot }
    </main>

    <!-- MOBILE BOTTOM NAV -->
    <nav class="lg:hidden"
         style="position:fixed; bottom:0; left:0; right:0; height:56px; background:#141414; border-top:0.5px solid #2a2a2a; display:flex; align-items:center; justify-content:space-around; z-index:30;">
        <a href="/" style="display:flex; flex-direction:column; align-items:center; gap:2px; flex:1; text-decoration:none; padding:6px 0;">
            <i class="ti ti-home" style="font-size:20px; color:#a3e635;"></i>
            <span style="font-size:10px; color:#a3e635;">Home</span>
        </a>
        <!-- SPIDER:BOTTOM_NAV_ITEMS -->
        <button @click="moreOpen = !moreOpen"
                style="display:flex; flex-direction:column; align-items:center; gap:2px; flex:1; background:transparent; border:none; cursor:pointer; padding:6px 0;">
            <i class="ti ti-dots" style="font-size:20px; color:#555;"></i>
            <span style="font-size:10px; color:#555;">More</span>
        </button>
    </nav>

    <!-- MOBILE MORE DRAWER -->
    <div :class="moreOpen ? 'translate-y-0' : 'translate-y-full'"
         style="position:fixed; bottom:56px; left:0; right:0; background:#1a1a1a; border-top:0.5px solid #2a2a2a; border-radius:12px 12px 0 0; padding:8px 0; z-index:40; transition:transform 0.25s cubic-bezier(.4,0,.2,1);"
         class="lg:hidden">
        <div style="width:32px; height:3px; background:#333; border-radius:99px; margin:0 auto 8px;"></div>
        <!-- SPIDER:MORE_ITEMS -->
        <a href="/settings" style="display:flex; align-items:center; gap:12px; padding:10px 20px; color:#aaa; text-decoration:none; font-size:13px;">
            <i class="ti ti-settings" style="font-size:18px; color:#555;"></i>
            Settings
        </a>
        <a href="/logout" style="display:flex; align-items:center; gap:12px; padding:10px 20px; color:#aaa; text-decoration:none; font-size:13px;">
            <i class="ti ti-logout" style="font-size:18px; color:#555;"></i>
            Logout
        </a>
    </div>

    <!-- TOAST -->
    <div x-data="{{show: false, message: '', type: 'success'}}"
         @item-saved.window="message = 'Saved!'; type = 'success'; show = true; setTimeout(() => show = false, 3000)"
         @item-deleted.window="message = 'Deleted!'; type = 'error'; show = true; setTimeout(() => show = false, 3000)"
         x-show="show"
         x-transition
         class="toast toast-top toast-end"
         style="z-index:100;">
        <div :class="type === 'success' ? 'alert alert-success' : 'alert alert-error'">
            <span x-text="message"></span>
        </div>
    </div>

    <script>
    function appShell() {
        return {
            sidebarOpen: false,
            drawerOpen: false,
            moreOpen: false,
        }
    }
    </script>

</body>
</html>