<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ title ?? "{{app_name}}" }</title>
    <link rel="stylesheet" href="/css/app.css">
    <link rel="stylesheet" href="/css/tabler-icons.min.css">
    <script defer src="/js/alpine.min.js"></script>
    <script src="/js/htmx.min.js"></script>
    <style>
        @font-face {
            font-family: 'tabler-icons';
            src: url('/fonts/tabler-icons.woff2') format('woff2');
            font-weight: normal;
            font-style: normal;
        }
    </style>
</head>
<body class="bg-base-100 min-h-screen" x-data="{{ moreOpen: false }}">

    <!-- NAVBAR -->
    <NavBar />  
  
    <!-- DRAWER LAYOUT -->
    <div class="drawer lg:drawer-open" style="padding-top:56px;">
        <input id="drawer-toggle" type="checkbox" class="drawer-toggle">

        <!-- MAIN CONTENT -->
        <div class="drawer-content min-h-screen pb-16 lg:pb-0 bg-base-100">
            <main class="p-4 lg:p-6">
                { slot }
            </main>
        </div>

        <!-- SIDEBAR -->
        <SideBar /> 
    </div>

    <!-- MOBILE BOTTOM NAV -->
    <MobileNav /> 
  
    <!-- TOAST -->
    <Toast /> 
</body>
</html>
